# ApexMonitor — variáveis de ambiente do app (copie para .env e preencha)
# O .env real NUNCA vai pro git. Este arquivo é só o modelo.

# --- Banco de dados ---
# DEV (local): SQLite em arquivo.
#   DATABASE_URL="file:./dev.db"
# PRODUÇÃO: Postgres (ver DEPLOY.md). Exemplo:
#   DATABASE_URL="postgresql://usuario:senha@host:5432/apexmonitor?schema=public"
DATABASE_URL="file:./dev.db"

# --- Criptografia dos segredos guardados (senha das contas de aposta) ---
# OBRIGATÓRIA EM PRODUÇÃO. Qualquer texto aleatório e longo serve (32+ caracteres).
# Gere um: openssl rand -base64 48
# ATENÇÃO: se você perder/trocar esta chave, as senhas já cifradas ficam ilegíveis.
APP_SECRET_KEY=""

# --- Trava de instalação do primeiro administrador ---
# OBRIGATÓRIA EM PRODUÇÃO. Sem ela, ninguém consegue criar o admin inicial pela web
# (é o que impede um estranho de virar dono num banco vazio).
# Gere um: openssl rand -hex 16
ADMIN_SETUP_TOKEN=""

# --- Agente de IA (tutor da comunidade) ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# --- Identificação legal e canal LGPD ---
# OBRIGATÓRIO antes da publicação oficial das páginas /privacidade e /termos.
LEGAL_ENTITY_NAME="ApexMonitor"
LEGAL_ENTITY_DOCUMENT=""
LEGAL_ENTITY_ADDRESS=""
PRIVACY_EMAIL="privacidade@apexmonitor.com.br"
