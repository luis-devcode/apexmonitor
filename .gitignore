# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files — NUNCA commitar (têm chave do Gemini, senha do coletor, etc.)
.env*
!.env.example

# banco local (hash de senhas, sessões, dados de teste)
*.db
*.db-journal
*.db-wal

# dados gerados pelo coletor (grandes e voláteis)
/integrations/**/data/*.json

# node_modules das integrações (o /node_modules acima só pega a raiz)
/integrations/**/node_modules

# perfil de navegador do coletor (login persistido)
.browser-profile
**/.browser-profile

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
