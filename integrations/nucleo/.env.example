# Fonte de dados (uso autorizado). Use uma conta dedicada: a fonte derruba
# sessão duplicada, então não compartilhe essa conta com outro acesso.
NUCLEO_URL=https://exemplo.com
NUCLEO_EMAIL=seu-email@exemplo.com
NUCLEO_PASS=sua-senha
# A cada quantos ms reescreve o arquivo de odds lido pela Central de Odds.
WRITE_INTERVAL_MS=1000
# Atualização dos endpoints auxiliares (Super Odds e catálogo de casas).
AUX_INTERVAL_MS=5000
